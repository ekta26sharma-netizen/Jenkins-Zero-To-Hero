pipeline {
    agent {
        docker {
            // Java 17 is required for modern SonarQube scanners
            image 'maven:3.9.6-eclipse-temurin-17' 
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock' 
        }
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo "Starting build number ${env.BUILD_NUMBER}"
            }
        }
        
        stage('Build and Test') {
            steps {
                sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
            }
        }
        
        stage('Static Code Analysis') {
            environment {
                SONAR_URL = "http://13.126.167.189:9000"
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    sh """
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                        mvn sonar:sonar \
                        -Dsonar.token=${SONAR_AUTH_TOKEN} \
                        -Dsonar.host.url=${SONAR_URL}
                    """
                }
            }
        }

        stage('Build and Push Docker Image') {
            environment {
                DOCKER_IMAGE = "ektavamika/ultimate-cicd:${env.BUILD_NUMBER}"
            }
            steps {
                script {
                    // Installs Docker CLI so the agent can talk to the host's Docker engine
                    sh 'apt-get update && apt-get install -y docker.io'
                    
                    sh "cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && docker build -t ${DOCKER_IMAGE} ."
                    
                    // Uses your updated 'docker-cred' (with the Access Token)
                    docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                        docker.image("${DOCKER_IMAGE}").push()
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh """
                        # Fix for 'fatal: not in a git directory'
                        git config --global --add safe.directory '*'
                        
                        git config user.email "jenkins@example.com"
                        git config user.name "Jenkins CI"
                        
                        # Update the deployment manifest with the new image tag
                        sed -i 's/replaceImageTag/${env.BUILD_NUMBER}/g' java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                        
                        git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                        git commit -m "Update image to version ${env.BUILD_NUMBER} [skip ci]" || echo "No changes to commit"
                        
                        # Push back to your repository
                        git push https://${GITHUB_TOKEN}@github.com/ekta26sharma-netizen/Jenkins-Zero-To-Hero.git HEAD:main
                    """
                }
            }
        }
    }
}
